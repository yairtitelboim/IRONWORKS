# Claude API Key (Required for AI orchestration)
REACT_APP_CLAUDE_API_KEY=your_claude_api_key_here

# Perplexity API Key (Now used only for tool button analysis)
# REACT_APP_PRP=your_perplexity_key_here

# Backend Environment Variables (Server-side only)
SERP_API_KEY=your_serp_api_key_here

# Google Places API Key (Fallback for SERP when offline/exceeded)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# AlphaEarth Service URL (will be updated after Phase 2)
REACT_APP_ALPHAEARTH_URL=http://localhost:5001

# Vercel KV Database (for caching)
KV_REST_API_URL=your_vercel_kv_url
KV_REST_API_TOKEN=your_vercel_kv_token

# Supabase (server-side queue metrics lookup for location_search card)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_QUEUE_METRICS_RPC=get_location_queue_metrics
# Optional RPC parameter overrides (defaults: lat/lng)
# SUPABASE_QUEUE_METRICS_LAT_PARAM=lat
# SUPABASE_QUEUE_METRICS_LNG_PARAM=lng

# ERCOT Public API (Phase 2 - Scanner)
ERCOT_API_KEY=your_ercot_api_key_here
ERCOT_API_BASE_URL=https://api.ercot.com

# Feedback email (server-side, sent via /api/ui/events when event_type=feedback_contact)
RESEND_API_KEY=your_resend_api_key
# Sender must be a verified sender/domain in Resend. For testing only, onboarding@resend.dev may work.
FEEDBACK_FROM_EMAIL=feedback@yourdomain.com
# Destination for received feedback
FEEDBACK_TO_EMAIL=titel.y@gmail.com
